# Esteira Garimpo — copie para .env quando rodar contra o Supabase.
# Sem isto, roda em modo jsonfile + fontes reais/fixture (offline).

# jsonfile (default, local) | supabase
GARIMPO_SINK=jsonfile
# caminho do store local quando sink=jsonfile
GARIMPO_JSON=garimpo.json

# real (rede: BrasilAPI etc.) | fixture (offline, deterministico)
GARIMPO_SOURCES=real
GARIMPO_BATCH=20
GARIMPO_DELAY=1.5

# --- necessarios quando GARIMPO_SINK=supabase ---
# service_role bypassa RLS (esteira e server-side). NUNCA exponha no front.
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# UUID do usuario dono (Authentication > Users). A esteira grava owner_id com ele.
OWNER_USER_ID=

# --- rascunho (Fase 3) ---
# mock (default, R$0, offline) | gemini (free tier Flash) | groq
GARIMPO_LLM=mock
# Gemini free tier e POR PROJETO. Crie a chave num projeto SEM billing (projeto
# com billing COBRA desde o 1o token). Pra somar cota, varias chaves de projetos
# diferentes, separadas por virgula. A copy tenta uma; se bater no limite do dia
# cai na proxima, depois no Groq (se GROQ_API_KEY), depois no mock.
GEMINI_API_KEYS=
# chave unica (alternativa a GEMINI_API_KEYS)
GEMINI_API_KEY=
# Flash do free tier. gemini-2.5-flash confirmado; o alias -latest as vezes da 503.
GEMINI_MODEL=gemini-2.5-flash

# --- captacao / descoberta (Maps -> bruto) ---
# fixture (default, offline) | places (Google Places — TEM CUSTO, nao R$0).
# Para R$0, a captacao vem pela extensao (varredura do Maps).
GARIMPO_MAPS=fixture
GOOGLE_MAPS_API_KEY=

# --- opcional ---
# Token da Meta Ad Library (sinal "ja anuncia?"). Sem ele, a fonte fica inerte.
# GRATIS: developers.facebook.com -> app -> produto "Ad Library API".
META_AD_LIBRARY_TOKEN=

# --- PageSpeed Insights (Google, GRATIS) ---
# Nota de performance do site (Lighthouse) + LCP, mesclada no site_signals.
# Liga sozinho quando ha a chave; ou forca com GARIMPO_PAGESPEED=1 (sem chave,
# cota baixa). Chave GRATUITA (sem cobranca) em console.cloud.google.com ->
# APIs -> "PageSpeed Insights API" -> Credenciais -> chave de API.
PAGESPEED_API_KEY=
# 1 = liga mesmo sem chave (cota baixa) | 0 = desliga | vazio = auto (liga se ha chave)
GARIMPO_PAGESPEED=

# --- avaliacoes do Google (Place Details New, SKU caro) ---
# Liga a coleta do teor das avaliacoes via Place Details. So roda em lead
# qualificado. Desligado por padrao porque o Place Details e o SKU mais caro
# do Places (cobra por chamada, independente de quantos campos voce pede).
# Requer GOOGLE_MAPS_API_KEY. Com GROQ_API_KEY, resume o teor via LLM.
GARIMPO_REVIEWS=0

# --- Instagram Business Discovery (opcional) ---
# ID numerico da pagina do Facebook vinculada ao IG Business da sua conta.
INSTAGRAM_BUSINESS_ID=
# Token de acesso com permissao instagram_basic + pages_read_engagement.
# Se vazio, cai no META_AD_LIBRARY_TOKEN (se ele tiver as permissoes certas).
INSTAGRAM_TOKEN=
# Quantos dias sem post considera o Instagram "parado" (default 60).
GARIMPO_IG_STALE_DAYS=60
