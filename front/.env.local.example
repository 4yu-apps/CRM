# Front Garimpo — copie para .env.local e preencha quando ligar no Supabase.
# Sem isto, o front roda em modo "mock" (dados em memoria), sem banco.

# mock (default) | supabase
NEXT_PUBLIC_DATA_SOURCE=mock

# Necessarios quando NEXT_PUBLIC_DATA_SOURCE=supabase
# (Dashboard > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
