{
  "manifest_version": 3,
  "name": "4YU CRM — WhatsApp + Maps",
  "version": "0.1.0",
  "description": "Card lateral read-only no WhatsApp Web e captacao de leads direto do Google Maps. Nunca envia.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://www.google.com/maps/*",
    "https://google.com/maps/*",
    "https://*.supabase.co/*",
    "https://crm.4yumkt.com.br/*"
  ],
  "background": { "service_worker": "background.bundle.js" },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.bundle.js"],
      "css": ["src/content/panel.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["wa-relay.bundle.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["wa-js.bundle.js", "wa-glue.bundle.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.google.com/maps/*",
        "https://google.com/maps/*"
      ],
      "js": ["maps.bundle.js"],
      "css": ["src/content/panel.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://crm.4yumkt.com.br/*",
        "https://*.vercel.app/*",
        "http://localhost/*"
      ],
      "js": ["crm-bridge.bundle.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/options/options.html",
  "action": {
    "default_title": "4YU CRM",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
