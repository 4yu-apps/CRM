# =====================================================================
# Garimpo — variaveis de ambiente (copie para .env e preencha)
# .env esta no .gitignore. NUNCA commitar segredos.
# =====================================================================

# --- BANCO (migrations) -----------------------------------------------
# Connection string DIRETA do Postgres (Dashboard > Project Settings >
# Database > Connection string > URI). Use a "Session pooler" (porta 5432)
# ou a conexao direta. Troque [PASSWORD] pela senha do banco.
# Usada por `supabase db push` (scripts/db-push.sh).
SUPABASE_DB_URL=postgresql://postgres.<ref>:[PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres

# --- API (runtime: front, extensao, esteira) --------------------------
# Dashboard > Project Settings > API
SUPABASE_URL=https://<ref>.supabase.co

# Chave publica (publishable / anon) — front Next.js e extensao Chrome.
# Pode aparecer no cliente; o RLS e quem protege.
SUPABASE_ANON_KEY=

# Chave secreta (service_role) — SO na esteira Python (server-side).
# Bypassa RLS. NUNCA no front nem na extensao.
SUPABASE_SERVICE_ROLE_KEY=

# --- ESTEIRA ----------------------------------------------------------
# UUID do usuario dono (o amigo). A esteira grava owner_id com este valor.
# Pega depois de criar o usuario no Supabase Auth (Authentication > Users).
OWNER_USER_ID=
